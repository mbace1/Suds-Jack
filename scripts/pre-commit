#!/usr/bin/env bash
# Pre-commit hook — enforces version log discipline.
#
# Install:  cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Re-install any time the script is updated in the repo.

GAME_CHANGED=$(git diff --cached --name-only | grep -E '^(toko-drop/|game\.js|index\.html|style\.css|levels\.json)')
if [ -z "$GAME_CHANGED" ]; then
  exit 0  # only infra / doc changes — no version entry required
fi

VERSIONS_STAGED=$(git diff --cached --name-only | grep -c '^VERSIONS\.md$')
if [ "$VERSIONS_STAGED" -eq 0 ]; then
  echo ""
  echo "  VERSIONS.md not updated."
  echo "  Game files are staged but VERSIONS.md has no changes."
  echo "  Add a ## vN entry and run: git add VERSIONS.md"
  echo ""
  exit 1
fi

# Warn when a version is a multiple of 10 — time to archive old entries.
LATEST_V=$(grep -m1 '^## v[0-9]' VERSIONS.md | grep -oE 'v[0-9]+' | grep -oE '[0-9]+')
if [ -n "$LATEST_V" ] && [ $(( LATEST_V % 10 )) -eq 0 ] && [ "$LATEST_V" -gt 0 ]; then
  # Allow commit if archiving was already done (only 1 active ## v entry remains)
  ACTIVE_V=$(grep -c '^## v[0-9]' VERSIONS.md || true)
  if [ "$ACTIVE_V" -le 1 ]; then
    exit 0  # archiving complete — only the new version entry remains
  fi
  ARCHIVE_END=$(( LATEST_V - 9 ))
  echo ""
  echo "  Version $LATEST_V is a multiple of 10 — time to archive!"
  echo "  Summarise v${ARCHIVE_END}–v$(( LATEST_V - 1 )) into the Archive section in VERSIONS.md."
  echo "  Then re-add VERSIONS.md and continue."
  echo ""
  exit 1
fi

exit 0
